HOST=0.0.0.0
PORT=8058

# Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret

# Keep false for the current office LAN deployment.
# If true, also set ALLOWED_ORIGINS to exact HTTPS app origins.
ALLOW_PUBLIC_ACCESS=false
ALLOWED_ORIGINS=http://localhost:8058,http://127.0.0.1:8058

# Current Excel backend guardrails.
JSON_BODY_LIMIT=25mb
MAX_EXCEL_BACKUPS=20

# Supabase SaaS migration target.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key
